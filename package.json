{
  "name": "@cordprotocol/sdk",
  "version": "0.4.0",
  "description": "Post-quantum cryptographic identity for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "cord": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "post-quantum",
    "cryptography",
    "ai-agents",
    "identity",
    "verifiable-credentials",
    "ed25519",
    "dilithium",
    "agentic-security",
    "agent-authentication",
    "mcp-security",
    "llm-agent-identity",
    "autonomous-agent-security",
    "did",
    "w3c"
  ],
  "author": "Cord Protocol",
  "license": "MIT",
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "commander": "^12.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
